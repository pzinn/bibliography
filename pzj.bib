@incollection {artic09,
    AUTHOR = {Zinn-Justin, Paul},
     TITLE = {Some matrix integrals related to knots and links},
 BOOKTITLE = {Random matrix models and their applications},
    SERIES = {Math. Sci. Res. Inst. Publ.},
