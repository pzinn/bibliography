      YEAR = {1998},
    NUMBER = {3},
     PAGES = {648--682},
      ISSN = {0550-3213},
     CODEN = {NUPBBO},
   MRCLASS = {82D35 (81R50 82B10)},
  MRNUMBER = {MR1643667 (2000i:82085)},
    arxiv = "cond-mat/9801158",
    abstract = {The SU(N) generalization of the multi-channel Kondo model with arbitrary rectangular impurity representations is considered by means of the Bethe Ansatz. The thermodynamics of the model is analyzed by introducing modified fusion equations for the impurity, leading to a simple description of the different IR fixed points of the theory. The entropy at zero temperature is discussed; in particular the overscreened case is explained in terms of quantum group representation.},
